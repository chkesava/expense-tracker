rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper for Admin access
    function isSuperAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "SUPER_ADMIN";
    }

    match /users/{userId} {
      // Allow search: Registered users can read basic profile info of others
      allow read: if request.auth != null;
      // Users can only edit THEIR OWN profile
      allow write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());

      match /{document=**} {
        // Keep personal subcollections (expenses, etc) private
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      }
    }

    // Shared Vaults Rules
    match /vaults/{vaultId} {
      // Access granted only if you are in the memberIds list
      allow read: if request.auth != null && (request.auth.uid in resource.data.memberIds || isSuperAdmin());
      
      // Allow creation if the creator sets themselves as the owner
      allow create: if request.auth != null && request.resource.data.ownerId == request.auth.uid;
      
      // Allow members to update (for adding new members or updating joint budget)
      allow update: if request.auth != null && (request.auth.uid in resource.data.memberIds || isSuperAdmin());
      
      // Only the owner or admin can delete the entire vault
      allow delete: if request.auth != null && (resource.data.ownerId == request.auth.uid || isSuperAdmin());

      // Vault expenses subcollection — accessible by vault members only
      match /expenses/{expenseId} {
        // Any vault member can read all expenses
        allow read: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/vaults/$(vaultId)).data.memberIds;

        // A vault member can create an expense; createdBy must match the logged-in user
        allow create: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/vaults/$(vaultId)).data.memberIds &&
          request.resource.data.createdBy == request.auth.uid;

        // Any vault member can update (e.g., split adjustments)
        allow update: if request.auth != null &&
          request.auth.uid in get(/databases/$(database)/documents/vaults/$(vaultId)).data.memberIds;

        // Only the creator or a super admin can delete
        allow delete: if request.auth != null && (
          resource.data.createdBy == request.auth.uid ||
          isSuperAdmin()
        );
      }
    }

    match /splits/{splitId} {
      // Access granted only if you are in the participantIds list
      allow read, update: if request.auth != null && (request.auth.uid in resource.data.participantIds || isSuperAdmin());
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      allow delete: if request.auth != null && (resource.data.createdBy == request.auth.uid || isSuperAdmin());
    }

    // Trip rules
    match /trips/{tripId} {
      allow read: if request.auth != null && (resource.data.userId == request.auth.uid || isSuperAdmin());
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update, delete: if request.auth != null && (resource.data.userId == request.auth.uid || isSuperAdmin());
      
      match /categoryBudgets/{budgetId} {
        allow read, write: if request.auth != null && (get(/databases/$(database)/documents/trips/$(tripId)).data.userId == request.auth.uid || isSuperAdmin());
      }
    }
  }
}
