rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper function to check if the user is a super admin based on their user document
    function isSuperAdmin() {
      return request.auth != null && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "SUPER_ADMIN";
    }

    match /users/{userId} {
      // Allow user to access their own profile OR Super Admin to access any profile
      allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());

      // Matches all subcollections including expenses, stats, subscriptions, accountTypes, accounts, and categories
      match /{document=**} {
        allow read, write: if request.auth != null && (request.auth.uid == userId || isSuperAdmin());
      }
    }

    match /splits/{splitId} {
      // Allow user to read if they are a participant
      allow read: if request.auth != null && (request.auth.uid in resource.data.participantIds || isSuperAdmin());
      
      // Allow create if user is authenticated and is the creator
      allow create: if request.auth != null && request.resource.data.createdBy == request.auth.uid;
      
      // Allow update if user is a participant
      allow update: if request.auth != null && (request.auth.uid in resource.data.participantIds || isSuperAdmin());
      
      // Allow delete if user is the creator
      allow delete: if request.auth != null && (resource.data.createdBy == request.auth.uid || isSuperAdmin());
    }
  }
}
