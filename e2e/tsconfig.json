{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@pages/*": ["./pages/*"],
      "@utils/*": ["./utils/*"],
      "@fixtures/*": ["./fixtures/*"],
      "@types/*": ["./types/*"],
      "@data/*": ["./test-data/*"]
    }
  },
  "include": ["./**/*.ts"],
  "exclude": ["../src", "../node_modules"]
}
